# TT-RSS Configuration
TTRSS_URL=https://tu-instancia-ttrss.com
TTRSS_USER=tu_usuario
TTRSS_PASSWORD=tu_password
TTRSS_TIMEOUT_SECONDS=60

# Google AI Studio
GOOGLE_API_KEY=tu_api_key
GOOGLE_MODEL=gemini-1.5-flash

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id
TELEGRAM_MODE=chat  # "chat" para 1:1, "supergroup" para grupos con topics

# Telegram Rate Limiting (para evitar errores 429)
TELEGRAM_MESSAGE_DELAY=1.5  # Segundos entre mensajes individuales
TELEGRAM_CATEGORY_DELAY=2.0  # Segundos entre cada categoría completa

# Wallabag Configuration
WALLABAG_URL=https://tu-instancia-wallabag.com
WALLABAG_CLIENT_ID=tu_client_id
WALLABAG_CLIENT_SECRET=tu_client_secret
WALLABAG_USERNAME=tu_usuario
WALLABAG_PASSWORD=tu_password
WALLABAG_DEFAULT_TAG=  # Tag adicional para todos los artículos (opcional, dejar vacío para no usar)

# General Configuration
ARTICLES_MAX_AGE_HOURS=24
LOG_LEVEL=INFO
TIMEZONE=UTC
MAX_ARTICLES_PER_RUN=500

# API retry configuration
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_SECONDS=5


# Summary Configuration
MAX_SUMMARY_TOKENS=2000
LLM_TEMPERATURE=0.3

# Scraping configuration
SCRAPING_ENABLED=true
SCRAPING_TIMEOUT_SECONDS=5
SCRAPING_DELAY_SAME_DOMAIN_SECONDS=2
SCRAPING_MAX_PARALLEL_DOMAINS=10
SCRAPING_MIN_WORDS=100

# Failed URLs cache
SCRAPING_CACHE_ENABLED=true
SCRAPING_CACHE_RETRY_AFTER_DAYS=7
SCRAPING_CACHE_MAX_RETRIES=1

# User-Agent configuration (fallback si detecta bloqueo)
SCRAPING_USER_AGENT_BOT=Mozilla/5.0 (compatible; RSS-Digest-Bot/1.0)
SCRAPING_USER_AGENT_BROWSER=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
SCRAPING_UA_FALLBACK_ENABLED=true

# Testing configuration
FIXTURE_TYPE=editado